<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/service-definition-3.xsd">
    <service verb="get" noun="TenantUserGroupIds">
        <description>Returns the set of user group ids [tenant group type] for the current logged in tenant.</description>
        <out-parameters>
            <parameter name="tenantGroupId" type="Set"/>
        </out-parameters>
        <actions>
            <set field="loggedInUser" from="ec.user.userAccount"/>

            <entity-find entity-name="moqui.security.UserGroupAndMember" cache="true" list="userGroupAndMemberList">
                <econdition field-name="userId" from="loggedInUser.userId"/>
                <econdition field-name="userGroupId" operator="not-equals" value="AllTenantAuth"/>
                <econdition field-name="groupTypeEnumId" value="UgtTenant"/>
                <date-filter/>
            </entity-find>

            <set field="tenantGroupId" from="userGroupAndMemberList.collect({ it.userGroupId })"/>
        </actions>
    </service>
</services>
